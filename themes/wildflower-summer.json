  "tokenColors": [
    {
      "name": "Lichen (Comments)",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "markup.quote.markdown"
      ],
      "settings": {
        "fontStyle": "bold italic",
        "foreground": "#a09080"
      }
    },
    {
      "name": "Paintbrush (this/self)",
      "scope": [
        "variable.language",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#d04028",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Thistle (Errors/Deleted)",
      "scope": [
        "markup.deleted",
        "support.type.exception",
        "token.error-token"
      ],
      "settings": {
        "foreground": "#d04028",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Balsamroot (Functions/Calls)",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "string.other.link.description.markdown",
        "string.other.link.title"
      ],
      "settings": {
        "foreground": "#1878b0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Poppy (Keywords)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "markup.raw.block.markdown"
      ],
      "settings": {
        "foreground": "#d87838",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Paintbrush (Storage/Tags)",
      "scope": [
        "storage.type",
        "storage.type.function",
        "storage.type.class.jsdoc",
        "entity.other",
        "support.type.property-name",
        "entity.name.tag.localname",
        "entity.other.attribute-name.html",
        "entity.name.tag",
        "meta.embedded.block.html",
        "markup.list",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#d04028",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Lupine (Types/Classes/Interfaces)",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "support.class",
        "support.type",
        "support.type.primitive",
        "entity.name.type.module"
      ],
      "settings": {
        "foreground": "#9080c8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Clover (Support/Builtins)",
      "scope": [
        "support"
      ],
      "settings": {
        "foreground": "#3a7a20",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Flax (Links/URLs)",
      "scope": [
        "meta.function.url",
        "markup.underline.link",
        "meta.link.reference",
        "variable.parameter.url"
      ],
      "settings": {
        "foreground": "#2080c8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Lavender (Constants/Modifiers)",
      "scope": [
        "constant.language",
        "entity.name.section.markdown",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a088c0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bachelor Button (Numbers)",
      "scope": [
        "constant.numeric",
        "constant.character.numeric"
      ],
      "settings": {
        "foreground": "#2080c8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Flax (Strings)",
      "scope": [
        "string.quoted",
        "punctuation.definition.string",
        "markup.fenced_code.block.markdown",
        "string.interpolated",
        "string.template",
        "markup.inline.raw.string",
        "constant.numeric.css",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#3078b8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Meadow (Escape sequences/Special operators)",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "constant.character.entity",
        "keyword.operator.new",
        "keyword.operator.ternary",
        "keyword.operator.quantifier",
        "keyword.operator.negation",
        "keyword.operator.unpacking",
        "keyword.operator.arithmetic",
        "keyword.operator.increment",
        "keyword.operator.decrement",
        "keyword.operator.channel",
        "keyword.operator.redirect",
        "keyword.operator.expansion",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.address",
        "keyword.operator.ellipsis",
        "punctuation.vararg-ellipses",
        "meta.separator.markdown",
        "markup.inserted.math.display.markdown"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#3a7a20"
      }
    },
    {
      "name": "Loam (Punctuation/Operators)",
      "scope": [
        "punctuation",
        "keyword.operator",
        "meta.brace",
        "meta.block",
        "constant.character",
        "markup.heading.setext",
        "punctuation.definition.list",
        "storage.type.function.arrow",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#887868",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Camas (Constants/Attributes)",
      "scope": [
        "meta.embedded.block",
        "meta.assertion",
        "meta.group.assertion",
        "entity.other.attribute-name",
        "string.unquoted.html",
        "constant.other",
        "variable.other.constant",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#8878b8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Sage (Variables)",
      "scope": [
        "variable.other",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#3e7228",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bunchgrass (Properties)",
      "scope": [
        "variable.object.property",
        "meta.definition.property",
        "meta.object",
        "meta.function-call.arguments"
      ],
      "settings": {
        "foreground": "#4a7a32",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Meadowgrass (Parameters)",
      "scope": [
        "variable.parameter",
        "variable.language.arguments",
        "storage.type.class",
        "keyword.generator.asterisk",
        "constant.other.character-class"
      ],
      "settings": {
        "foreground": "#3a7a20",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable.language.arguments",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#3a7a20",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Larkspur (Decorators/Annotations)",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#a888c0",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Scarlet Gilia (Bold/CSS special)",
      "scope": [
        "keyword.operator.expression.in",
        "keyword.operator.expression.of",
        "meta.at-rule.font-face.css",
        "punctuation.definition.keyword.css",
        "keyword.control.at-rule.font-face.css",
        "punctuation.definition.block.tag.jsdoc",
        "markup.bold",
        "entity.name.tag.wildcard.scss",
        "punctuation.definition.entity.css"
      ],
      "settings": {
        "foreground": "#d04028",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Clover (Exports/Imports)",
      "scope": [
        "keyword.control.export",
        "keyword.control.from",
        "support.type.object.module"
      ],
      "settings": {
        "foreground": "#3a7a20",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Lupine (Control flow)",
      "scope": [
        "keyword.control.default",
        "keyword.control.trycatch",
        "keyword.control.switch",
        "entity.other.attribute-name.pseudo-class.css"
      ],
      "settings": {
        "foreground": "#9080c8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Fern (Loops/Infinity)",
      "scope": [
        "constant.language.infinity",
        "constant.language.nan",
        "keyword.control.loop.js"
      ],
      "settings": {
        "foreground": "#1878b0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Trillium (Global variables)",
      "scope": [
        "variable.other.global"
      ],
      "settings": {
        "foreground": "#1878b0",
        "fontStyle": "bold"
      }
    }
  ]
}
